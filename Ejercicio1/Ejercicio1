
import productos
import ventas
import json

datos_productos = []

def guardar_json():

    with open("productos.json", "w") as archivo:
        json.dump(datos_productos, archivo, indent=4)


def cargar_json():

    global datos_productos

    try:
        with open("productos.json", "r") as archivo:
            datos_productos = json.load(archivo)

    except FileNotFoundError:
        datos_productos = []


def menu():

    while True:

        print("1. Agregar Producto")
        print("2. Ver Productos")
        print("3. Buscar Productos")
        print("4. Modificar Productos")
        print("5. Eliminar Producto")
        print("6. Registrar Venta")
        print("7. Salir")

        opcion = input("Seleccione una opción: ")


        if opcion == "1":
            productos.agregar_producto(datos_productos)
            guardar_json()
        elif opcion == "2":
            productos.ver_productos(datos_productos)

        elif opcion == "3":
           productos.buscar_productos(datos_productos)

        elif opcion == "4":
          productos.modificar_producto(datos_productos)
          guardar_json()

        elif opcion == "6":
          ventas.registrar_ventas(datos_productos)

        elif opcion == "5":
          productos.eliminar_producto(datos_productos)
          guardar_json()

        elif opcion == "7":
            print("Saliendo del programa...")
            exit()
cargar_json()
menu()


